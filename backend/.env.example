# GitHub OAuth Configuration
# Create a GitHub OAuth App at: https://github.com/settings/developers
# For local: http://localhost:4500/api/auth/github/callback
# For production: https://your-app.railway.app/api/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Frontend URL (where to redirect after OAuth)
# Local: http://localhost:5173
# Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173

# Backend URL (for OAuth callback)
# Local: http://localhost:4500
# Production: https://your-app.railway.app
BACKEND_URL=http://localhost:4500

# IBM watsonx.ai Configuration
# Get credentials from: https://cloud.ibm.com/iam/apikeys
# Project ID from: https://dataplatform.cloud.ibm.com/projects
WATSONX_API_KEY=your_watsonx_api_key
WATSONX_PROJECT_ID=your_watsonx_project_id
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Server Configuration
# Railway will set PORT automatically
PORT=4500
NODE_ENV=development